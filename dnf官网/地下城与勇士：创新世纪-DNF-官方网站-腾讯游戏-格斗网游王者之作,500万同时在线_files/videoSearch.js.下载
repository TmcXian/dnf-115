    let allData = await fetchVideoDataByColumn(columnUid).catch(() => []);

    // TODO: 测试用 - 官方视频栏目虚拟扩充到60条，验证分页效果，上线前删除
    // if (columnUid === 30050 && allData.length > 0) {
    //     let mockData = [];
    //     while (mockData.length < 60) {
    //         mockData = mockData.concat(allData.map((item, idx) => ({
    //             ...item,
    //             title: item.title + ' (' + (mockData.length + idx + 1) + ')',
    //             documentId: item.documentId + '_' + (mockData.length + idx)
    //         })));
    //     }
    //     allData = mockData.slice(0, 60);
    // }

    // 排序
    const sortedData = notSort ? allData : sortVideoList([...allData]);

    // 设置总数用于分页
    window.totalVideo = sortedData.length;

    // 分页截取
    const startIndex = (currentPage - 1) * cusSize;
    const pageData = sortedData.slice(startIndex, startIndex + cusSize);

    return pageData;
}