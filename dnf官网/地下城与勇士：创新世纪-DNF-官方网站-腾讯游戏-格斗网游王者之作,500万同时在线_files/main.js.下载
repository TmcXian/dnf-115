// 展示视频（首页-不传category时拉全量，传category时按栏目拉取）
async function showVideoList(category) {
    const list = await getVideoList(5, category);
    // 头条
    const topItem = list[0];
    if(topItem) {
        const imgUrl = topItem['cover_image'] || '';
        $('.top-guide').html(`
            <a href="javascript:showVideoPop('${topItem['video']}')" onclick="PTTReporter('btn', 'video', '头条视频');" class="top-guide-link" title="${topItem['title']}">
                <img src="${imgUrl}" class="top-guide-image" alt="${topItem['title']}">
                <span class="top-guide-mask"></span>
                <span class="top-guide-tit">${topItem['title']}</span>
            </a>           
        `)
    }

    let videoHtml = '';
    // 后4条
    for (let i = 1; i < 5; i++) {
        const item = list[i];
        if (!item) break;
        const imgUrl = item['cover_image'] || '';
        videoHtml += `
            <li>
				<a href="javascript:showVideoPop('${item['video']}')" class="guide-link" title="${item['title']}" onclick="PTTReporter('btn', 'video', '视频${i}');">
                    <img src="${imgUrl}" class="guide-image" alt="${item['title']}">
                    <span class="guide-mask"></span>
                    <span class="guide-tit">${item['title']}</span>
                </a> 
			</li>
        `
    }
    $('.guide-list').html(videoHtml);
}

