// 红点
const redText = ['创作激励计划','活动合集页','时装实验室','极速版专题','网吧特权']
let redIsClicked = [];
$('.nav li a').each(function() {
    const text = $(this).text();
    const has = redText.indexOf(text)>-1;
    redIsClicked = JSON.parse(window.localStorage.getItem('redIsClicked0611')) || [];
    const isClicked = redIsClicked.indexOf(text)>-1;
    if(text && has && !isClicked) {
        $(this).addClass('dot-new');
        $(this).parent().parent().parent().addClass('dot');
    }
})
$('a.dot-new').on('click',function() {
    if($(this).hasClass('dot-new')) {
        const text = $(this).text();
        $(this).removeClass('dot-new');
        $(this).parent().parent().parent().removeClass('dot');
        redIsClicked.push(text);
        console.log(redIsClicked)
        window.localStorage.setItem('redIsClicked0611',JSON.stringify(redIsClicked));
    }
})

